  <Dialog id="12" name="MSG_011_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 1 -1 -1 0 0}{f 3 1 1 0 0 17 0 0}{f 5 13 13 15 110}Really!? You promise!?[n]{f 1 1}]]></Page>
