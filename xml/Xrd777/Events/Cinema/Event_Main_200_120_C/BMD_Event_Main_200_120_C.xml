    <Speaker id="0" rawBytes="41 69 67 69 73">Aigis</Speaker>
    <Speaker id="1" rawBytes="52 79 6F 6A 69 20 4D 6F 63 68 69 7A 75 6B 69">Ryoji Mochizuki</Speaker>
