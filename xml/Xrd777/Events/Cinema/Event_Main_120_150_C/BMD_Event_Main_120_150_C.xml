  <Dialog id="3" name="MSG_002_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 2 6 51 -1 0 0}{f 3 1 1 0 0 4 0 0}Phew. It was just a security guard.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="SEL_003_0_0" type="Selection">
    <Option><![CDATA[{f 0 5 254}{f 2 1}Let's hurry.]]></Option>
    <Option><![CDATA[{f 0 5 254}{f 2 1}You're freaking out.]]></Option>
