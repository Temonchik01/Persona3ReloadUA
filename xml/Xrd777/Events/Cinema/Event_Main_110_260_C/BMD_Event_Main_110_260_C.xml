  <Dialog id="1" name="MSG_001_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 3 2 51 -1 0 0}{f 3 1 1 0 0 2 0 0}There it is![n]{f 1 1}]]></Page>
