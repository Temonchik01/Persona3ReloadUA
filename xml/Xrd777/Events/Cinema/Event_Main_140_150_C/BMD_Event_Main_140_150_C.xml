  </Dialog>
  <Dialog id="13" name="MSG_011_5_0" type="Message">
    <Page spk="0008"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 224 0 -1 -1 0 0}{f 3 1 1 0 0 15 0 0}I heard the news. There isn't much here, but make yourselves comfortable.[n]{f 1 1}]]></Page>
  </Dialog>
