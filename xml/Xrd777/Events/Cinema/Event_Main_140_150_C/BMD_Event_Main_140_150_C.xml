  <Dialog id="20" name="MSG_017_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 3 1 5 -1 0 0}{f 3 1 1 0 0 24 0 0}Sweet! This is gonna rock![n]{f 1 1}]]></Page>
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 3 1 5 -1 0 0}{f 3 1 1 0 0 25 0 0}Hey, wanna go to the beach? It's literally right there![n]{f 1 1}]]></Page>
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 3 1 5 -1 0 0}{f 3 1 1 0 0 26 0 0}Oh man, I'm so ready for this! Come on, let's go![n]{f 1 1}]]></Page>
  </Dialog>
