  <Dialog id="5" name="MSG_004_0_0" type="Message">
    <Page spk="0005"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 5 0 5 -1 0 0}{f 3 1 1 0 0 6 0 0}We won't be here long, but I'll be relying on you during our stay.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MSG_005_0_0" type="Message">
