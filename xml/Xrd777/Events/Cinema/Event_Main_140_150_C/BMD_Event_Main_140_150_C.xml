  </Dialog>
  <Dialog id="7" name="MSG_006_0_0" type="Message">
    <Page spk="0007"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 8 0 0}{f 5 21 0 1501}And you must be her associates from school, correct? Welcome to the Kirijo vacation home.[n]{f 1 1}]]></Page>
