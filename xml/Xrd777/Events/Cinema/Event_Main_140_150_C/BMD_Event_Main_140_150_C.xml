  <Dialog id="19" name="MSG_016_0_0" type="Message">
    <Page spk="0005"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 5 1 5 -1 0 0}{f 3 1 1 0 0 23 0 0}We won't be here long, but make yourself at home.[n]{f 1 1}]]></Page>
