<?xml version="1.0" encoding="UTF-8"?>
<BMD source="BMD_Event_Cmmu_105_020_C.uasset" sourcePath="D:\Modding\Reloaded 2\Mods\p3r.asset.ukrainian\tools\dds_l10n\source\Xrd777\Events\Cinema\Event_Cmmu_105_020_C\BMD_Event_Cmmu_105_020_C.uasset" dialogs="18">
  <Speakers>
    <Speaker id="0" rawBytes="4B 61 7A 75 73 68 69 20 4D 69 79 61 6D 6F 74 6F">Кадзуші Міямото</Speaker>
  </Speakers>
  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 5 151 -1 0 0}{f 3 1 1 0 0 1 0 0}М-мій бік... Здається, я переборщив.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="SEL_001_0_0" type="Selection">
    <Option><![CDATA[{f 0 5 254}{f 2 1}Не перенапружуйся.]]></Option>
    <Option><![CDATA[{f 0 5 254}{f 2 1}Мужайся!]]></Option>
  </Dialog>
  <Dialog id="2" name="MSG_002_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 5 151 -1 0 0}{f 3 1 1 0 0 2 0 0}Я ще не здаюсь. Можу продовжувати.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_003_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 151 -1 0 0}{f 3 1 1 0 0 3 0 0}{f 5 13 8 5 105}Легко тобі казати... Але, чесно, може, ти й правий.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_004_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 151 -1 0 0}{f 3 1 1 0 0 4 0 0}А ти як? Все нормально? Ти ж гнешся без відпочинку.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 151 -1 0 0}{f 3 1 1 0 0 5 0 0}Навіть не виглядаєш змореним... Ей, який у тебе режим тренувань?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="SEL_005_0_0" type="Selection">
    <Option><![CDATA[{f 0 5 254}{f 2 1}Звичайний розпорядок.]]></Option>
    <Option><![CDATA[{f 0 5 254}{f 2 1}Особливий, дуже.]]></Option>
  </Dialog>
  <Dialog id="6" name="MSG_006_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 151 -1 0 0}{f 3 1 1 0 0 6 0 0}О, та ти кажеш так, ніби це дурниці. А я тут помираю.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MSG_007_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 151 -1 0 0}{f 3 1 1 0 0 7 0 0}Так і думав. Інакше чого б я тут корчився...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="8" name="MSG_008_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 151 -1 0 0}{f 3 1 1 0 0 8 0 0}Ти реально скажений, {f 4 1}.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 151 -1 0 0}{f 3 1 1 0 0 9 0 0}Це трохи засмучує... Ти мене повністю розніс.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 151 -1 0 0}{f 3 1 1 0 0 10 0 0}Я знав, що тут високі стандарти, але не думав, що мені доведеться тренуватись поруч із кимось настільки крутим.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="9" name="MSG_009_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 2 151 -1 0 0}{f 3 1 1 0 0 11 0 0}Гаразд, я вирішив![n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 2 151 -1 0 0}{f 3 1 1 0 0 12 0 0}Слухай, {f 4 1}! Готуйся ковтати пил![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="10" name="MND_010_0_0" type="Message">
    <Page spk="FFFF"><![CDATA[{f 0 5 254}{f 2 1}Схоже, Міямото бачить у мені суперника.[n]{f 1 1}]]></Page>
    <Page spk="FFFF"><![CDATA[{f 0 5 254}{f 2 1}Я відчуваю, що наші стосунки зміцнились...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="11" name="SYS_011_0_0" type="Message"/>
  <Dialog id="12" name="MSG_012_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 151 -1 0 0}{f 3 1 1 0 0 13 0 0}Вибач, я не хотів так заводитись.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="13" name="MSG_012_5_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 5 151 -1 0 0}{f 3 1 1 0 0 14 0 0}Піш... Ахх![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="14" name="SEL_013_0_0" type="Selection">
    <Option><![CDATA[{f 0 5 254}{f 2 1}Що таке?]]></Option>
    <Option><![CDATA[{f 0 5 254}{f 2 1}Ходімо вже.]]></Option>
  </Dialog>
  <Dialog id="15" name="MSG_014_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 5 151 -1 0 0}{f 3 1 1 0 0 15 0 0}Здається... Я підвернув коліно.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="16" name="MSG_014_3_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 1 151 -1 0 0}{f 3 1 1 0 0 16 0 0}Забудь. Ходімо.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="17" name="MND_015_0_0" type="Message">
    <Page spk="FFFF"><![CDATA[{f 0 5 254}{f 2 1}Я попрощався з Міямото[n]й повернувся до гуртожитку.[n]{f 1 1}]]></Page>
  </Dialog>
</BMD>
