  </Dialog>
  <Dialog id="6" name="MSG_006_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 2 0 0}I am the voice of your inner self...[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 3 0 0}Revel in the moment...[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 4 0 0}That which cannot be felt is merely a dream... The present is all we have.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="SEL_007_0_0" type="Selection">
