    <Option><![CDATA[{f 0 5 254}{f 2 1}I don't understand...]]></Option>
  </Dialog>
  <Dialog id="10" name="MSG_010_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 7 0 0}Pleasure is what you truly seek.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 8 0 0}You stand before the doorway to bliss.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 9 0 0}You cannot deny your instincts... Embrace your desire...[n]{f 1 1}]]></Page>
  </Dialog>
