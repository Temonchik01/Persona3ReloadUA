  <Dialog id="5" name="MSG_005_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 4 0 1 -1 0 0}{f 3 1 1 0 0 6 0 0}There's a new threat. Persona-users, just like us.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MSG_006_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 10 3 -1 -1 0 0}{f 3 1 0 0 0 7 0 0}......[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 10 3 -1 -1 0 0}{f 3 1 1 0 0 8 0 0}So? That's not my problem.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MSG_007_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 4 0 1 -1 0 0}{f 3 1 1 0 0 9 0 0}That's not everything.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="8" name="MSG_008_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 4 3 1 -1 0 0}{f 3 1 1 0 0 10 0 0}...Amada has joined our team.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="9" name="MSG_008_5_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 17 10 2 1}]]></Page>
