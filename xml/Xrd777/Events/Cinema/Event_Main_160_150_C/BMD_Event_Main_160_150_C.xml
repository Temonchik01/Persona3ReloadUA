  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 10 2 -1 -1 0 0}{f 3 1 1 0 0 1 0 0}You're really starting to piss me off.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_001_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 4 0 1 -1 0 0}{f 3 1 1 0 0 2 0 0}Things have changed. Sorry, but I'm not taking "no" for an answer this time.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="MSG_002_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 10 0 -1 -1 0 0}{f 3 1 1 0 0 3 0 0}What?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_003_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 4 0 1 -1 0 0}{f 3 1 1 0 0 4 0 0}This belongs to you.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_004_0_0" type="Message">
