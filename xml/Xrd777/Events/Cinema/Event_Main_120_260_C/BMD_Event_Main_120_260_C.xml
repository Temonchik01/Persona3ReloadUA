  </Dialog>
  <Dialog id="3" name="MSG_003_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 6 3 2 -1 0 0}{f 3 1 1 0 0 4 0 0}Ти в порядку?[n]{f 1 1}]]></Page>
