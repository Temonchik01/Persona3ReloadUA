<BMD source="BMD_Event_Cmmu_110_030_C.uasset" sourcePath="D:\Modding\Reloaded 2\Mods\p3r.asset.ukrainian\tools\dds_l10n\source\Xrd777\Events\Cinema\Event_Cmmu_110_030_C\BMD_Event_Cmmu_110_030_C.uasset" dialogs="18">
  <Speakers>
    <Speaker id="0" rawBytes="4D 61 69 6B 6F">Маїко</Speaker>
    <Speaker id="1" rawBytes="54 68 69 6E 20 59 6F 75 6E 67 20 4D 61 6E">Худорлявий юнак</Speaker>
  </Speakers>
  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 0 -1 -1 0 0}{f 3 1 1 0 0 1 0 0}Гей, гей![n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 0 -1 -1 0 0}{f 3 1 1 0 0 2 0 0}Ти бачив Смугастика?[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 1 0 0 3 0 0}{f 4 23 0 1 2 25 25}Ми грали в піжмурки, але… я не знаю, куди він подівся.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_000_5_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 1 -1 -1 0 0}{f 3 1 1 0 0 4 0 0}О! Смугастик! Ось ти де![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="MSG_001_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 117 0 -1 -1 0 0}{f 3 1 0 0 0 5 0 0}......[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_002_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 0 -1 -1 0 0}{f 3 1 1 0 0 6 0 0}Виглядаєш не дуже… Ти захворів?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_003_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 117 0 -1 -1 0 0}{f 3 1 1 0 0 7 0 0}Так... Дивно, що ти помітила.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="MSG_004_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 3 -1 -1 0 0}{f 3 1 1 0 0 8 0 0}Га?.. Ти справді захворів?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MSG_005_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 117 1 -1 -1 0 0}{f 3 1 1 0 0 9 0 0}Ха-ха, ні. Я пожартував. Тебе так легко надурити, Маіко.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MSG_006_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 1 0 0 10 0 0}Не чесно, я ж тобі повірила! Не дражни мене тільки тому, що я маленька![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="8" name="MSG_007_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 117 0 -1 -1 0 0}{f 3 1 1 0 0 11 0 0}А ти хто?..[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="9" name="SEL_008_0_0" type="Selection">
    <Option><![CDATA[{f 0 5 254}{f 2 1}Я друг Маіко.]]></Option>
    <Option><![CDATA[{f 0 5 254}{f 2 1}Просто повз проходив.]]></Option>
  </Dialog>
  <Dialog id="10" name="MSG_009_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 117 0 -1 -1 0 0}{f 3 1 1 0 0 12 0 0}Ага... То це про тебе вона говорила. Мені було цікаво, який ти...[n]{f 1 1}]]></Page>
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 117 0 -1 -1 0 0}{f 3 1 1 0 0 13 0 0}Ти бачиш себе її опікуном чи ви просто діти, що граються разом?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="11" name="MSG_010_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 1 -1 -1 0 0}{f 3 1 1 0 0 14 0 0}Гей, я голодна! Хочу такоякі! Такоякі![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="12" name="MSG_011_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 1 -1 -1 0 0}{f 3 1 1 0 0 15 0 0}Ти теж можеш поїсти з нами, Смугастику![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="13" name="MSG_012_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 117 0 -1 -1 0 0}{f 3 1 1 0 0 16 0 0}Ні... Дякую, я відмовлюсь.[n]{f 1 1}]]></Page>
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 117 0 -1 -1 0 0}{f 3 1 1 0 0 17 0 0}До зустрічі![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="14" name="MSG_013_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 1 0 0 18 0 0}Він пішов...[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 0 -1 -1 0 0}{f 3 1 1 0 0 19 0 0}{f 4 23 0 1 0 25 25}Зазвичай я його бачу поруч із {f 0 1 2}храмом{f 0 1 27} {f 0 1 2}щонеділі{f 0 1 27}.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 0 -1 -1 0 0}{f 3 1 1 0 0 20 0 0}Я проходжу повз, коли йду до репетитора.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 1 -1 -1 0 0}{f 3 1 1 0 0 21 0 0}{f 4 23 0 1 1 25 25}Гаразд, гайда на такоякі![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="15" name="MSG_014_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 117 0 -1 -1 0 0}{f 3 1 1 0 0 22 0 0}Рідко можна побачити, щоб люди проходили повз цей храм.[n]{f 1 1}]]></Page>
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 117 0 -1 -1 0 0}{f 3 1 1 0 0 23 0 0}Зазвичай тут так тихо, як на кладовищі.[n]{f 1 1}]]></Page>
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 117 0 -1 -1 0 0}{f 3 1 0 0 0 24 0 0}......[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="16" name="MSG_015_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 117 0 -1 -1 0 0}{f 3 1 1 0 0 25 0 0}Ну, мені краще йти. Починає холоднішати.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="17" name="MSG_016_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 1 0 0 26 0 0}Га? Він уже пішов?[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 0 -1 -1 0 0}{f 3 1 1 0 0 27 0 0}{f 4 23 0 1 0 25 25}Зазвичай я його бачу поруч із {f 0 1 2}храмом{f 0 1 27} {f 0 1 2}щонеділі{f 0 1 27}.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 0 -1 -1 0 0}{f 3 1 1 0 0 28 0 0}Я проходжу повз, коли йду до репетитора.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 0 -1 -1 0 0}{f 3 1 1 0 0 29 0 0}Ох, я собі набігала апетит![n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 1 -1 -1 0 0}{f 3 1 1 0 0 30 0 0}{f 4 23 0 1 1 25 25}Пішли поїмо такоякі![n]{f 1 1}]]></Page>
  </Dialog>
</BMD>
