  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Kyoto, huh? That's so cliché...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_001_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}Huh? You're not a fan?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="MSG_001_5_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}I'd say it's a beautiful city to make some[n]good memories in while we're still young.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_002_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Man, is that really the first thing you think?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_002_5_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}It makes you sound like an old geezer[n]when you say that kinda stuff.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="MSG_003_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}It does?[n]{f 1 1}]]></Page>
  </Dialog>
