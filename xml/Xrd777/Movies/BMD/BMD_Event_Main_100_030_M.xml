  </Dialog>
  <Dialog id="19" name="MSG_014_0_0" type="Message">
    <Page spk="000B"><![CDATA[{f 0 5 254}{f 2 1}Ugh, there's no way! I can't![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="20" name="MSG_015_0_0" type="Message">
    <Page spk="000C"><![CDATA[{f 0 5 254}{f 2 1}Your attention please. Today's[n]train schedule will be modified...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="21" name="MSG_015_5_0" type="Message">
