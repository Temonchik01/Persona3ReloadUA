  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Time never waits.[n]It delivers all equally to the same end.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}You, who wish to safeguard the future, however limited it may be...[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}You will be given one year;[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}go forth without falter,[n]with your heart as your guide...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_001_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}ほら、こーいうフツーの醤油が[n]うまいのが名店なのよ。[cr][n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="MSG_002_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}マジー？　つかノブ君、[cr][n]普段あんまラーメンとか食べなくない？[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_003_0_0" type="Message">
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}そんなの常識じゃね？[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_004_0_0" type="Message">
    <Page spk="0004"><![CDATA[{f 0 5 254}{f 2 1}コレ、超良くない！？[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="MSG_005_0_0" type="Message">
    <Page spk="0005"><![CDATA[{f 0 5 254}{f 2 1}えー何？　みしてみしてー！[cr][n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MSG_006_0_0" type="Message">
    <Page spk="0006"><![CDATA[{f 0 5 254}{f 2 1}ヤバい、何コレ！？　カワイーー！[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MSG_007_0_0" type="Message">
    <Page spk="0007"><![CDATA[{f 0 5 254}{f 2 1}どうぞー。[cr][n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="8" name="MSG_008_0_0" type="Message">
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}しらねえの？　ダサ…[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="9" name="MSG_009_0_0" type="Message">
    <Page spk="0008"><![CDATA[{f 0 5 254}{f 2 1}マジこいつ？[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="10" name="MSG_010_0_0" type="Message">
    <Page spk="0009"><![CDATA[{f 0 5 254}{f 2 1}何？　今から行くの？[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="11" name="MSG_011_0_0" type="Message">
    <Page spk="000A"><![CDATA[{f 0 5 254}{f 2 1}あー暇暇。すぐ行くわー。[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="12" name="MSG_012_0_0" type="Message">
    <Page spk="000B"><![CDATA[{f 0 5 254}{f 2 1}*gasp* *gasp*[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="13" name="MSG_012_3_0" type="Message">
    <Page spk="000B"><![CDATA[{f 0 5 254}{f 2 1}Just put it... to my head...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="14" name="MSG_012_5_0" type="Message">
    <Page spk="000B"><![CDATA[{f 0 5 254}{f 2 1}And then pull the trigger...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="15" name="MSG_012_7_0" type="Message">
    <Page spk="000B"><![CDATA[{f 0 5 254}{f 2 1}Come on...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="16" name="MSG_013_0_0" type="Message">
    <Page spk="000B"><![CDATA[{f 0 5 254}{f 2 1}*sigh*[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="17" name="MSG_013_5_0" type="Message">
    <Page spk="000B"><![CDATA[{f 0 5 254}{f 2 1}*sigh*[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="18" name="MSG_013_7_0" type="Message">
