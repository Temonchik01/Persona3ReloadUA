  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}I remember now...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_000_5_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}That's right. After my father died... there[n]was a time I lost motivation to live my life.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="MSG_001_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}Huh? Am I... forgetting something?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_002_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}Huh? Sanada-senpai?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_002_5_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}Wh-What're you doing!?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="MSG_003_0_0" type="Message">
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}...Koromaru![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MSG_004_0_0" type="Message">
    <Page spk="0004"><![CDATA[{f 0 5 254}{f 2 1}Arf![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MSG_005_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}But no longer. I shall honor my father's will.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="8" name="MSG_005_3_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}I won't run from the future... I'll face it head-on.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="9" name="MSG_005_5_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Not a single doubt remains[n]in my mind. And the reason...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="10" name="MSG_006_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}Our promise![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="11" name="MSG_007_0_0" type="Message">
    <Page spk="0005"><![CDATA[{f 0 5 254}{f 2 1}Mitsuru![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="12" name="MSG_008_0_0" type="Message">
    <Page spk="0006"><![CDATA[{f 0 5 254}{f 2 1}That's right...![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="13" name="MSG_009_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}It's because I have forged such wonderful friendships...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="14" name="MSG_009_5_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}And we swore that we would never lose hope,[n]no matter what the future may bring![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="15" name="MSG_010_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}Senpai! We remembered him and Aigis![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="16" name="MSG_011_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Yes, I did as well.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="17" name="MSG_012_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Let's go... They're waiting.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="18" name="MSG_013_0_0" type="Message">
    <Page spk="0007"><![CDATA[{f 0 5 254}{f 2 1}Uh, hello? This is a ceremony! We're not done![n]{f 1 1}]]></Page>
  </Dialog>
