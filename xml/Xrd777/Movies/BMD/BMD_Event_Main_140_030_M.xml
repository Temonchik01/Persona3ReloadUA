  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}My grandfather was obsessed with the Shadows...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_000_3_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}He wanted to harness their power[n]to create something extraordinary.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="MSG_001_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}Create something extraordinary...?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_002_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}To that end, he assembled a research team[n]and had them amass a number of Shadows.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_003_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}He was collectin' 'em!?[n]Damn, that's freakin' crazy![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="MSG_004_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}But ten years ago, during the final stages of the project,[n]there was an accident... and the experiment failed.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MSG_004_3_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}They lost control of the Shadows' power,[n]altering the nature of the entire world.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MSG_005_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}You can't mean...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="8" name="MSG_006_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Yes... Tartarus and the Dark Hour.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="9" name="MSG_007_0_0" type="Message">
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}......[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="10" name="MSG_008_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}Huh!?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="11" name="MSG_009_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}Huh!?[n]{f 1 1}]]></Page>
  </Dialog>
