  </Dialog>
  <Dialog id="2" name="MSG_002_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 1581 0 -1 -1 0 0}{f 3 1 3 0 -1 15813 0 0}{f 5 21 1 201}Umm, {f 4 1}-kun... To get to your room...[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 1581 0 -1 -1 0 0}{f 5 21 1 201}Go up the stairs and turn right. Your room will be on the right-hand side at the end of the hall.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 1581 0 -1 -1 0 0}{f 5 21 1 201}Got it? Now go.[n]{f 1 1}]]></Page>
