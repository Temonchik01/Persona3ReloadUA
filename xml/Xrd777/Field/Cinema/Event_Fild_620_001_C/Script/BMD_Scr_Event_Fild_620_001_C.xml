  <Dialog id="6" name="MSG_004_0_0" type="Message">
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 6 4 -1 50 0 0}{f 3 1 3 0 -1 5076 0 0}Oh! Could it be...!?[n]{f 1 1}]]></Page>
