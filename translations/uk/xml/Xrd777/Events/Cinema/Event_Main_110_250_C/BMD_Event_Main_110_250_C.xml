  <Dialog id="4" name="MSG_003_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 5 2 51 50 0 0}{f 3 1 1 0 0 7 0 0}Щось не так? Що у вас сталось?![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="MSG_004_0_0" type="Message">
