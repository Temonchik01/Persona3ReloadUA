  <Dialog id="3" name="MSG_002_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 3 2 51 -1 0 0}{f 3 1 1 0 0 6 0 0}Блін, не відчиняється![n]{f 1 1}]]></Page>
