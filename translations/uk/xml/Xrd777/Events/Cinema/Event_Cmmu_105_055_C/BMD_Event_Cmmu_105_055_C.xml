<?xml version="1.0" encoding="UTF-8"?>
<BMD source="BMD_Event_Cmmu_105_055_C.uasset" sourcePath="D:\Modding\Reloaded 2\Mods\p3r.asset.ukrainian\tools\dds_l10n\source\Xrd777\Events\Cinema\Event_Cmmu_105_055_C\BMD_Event_Cmmu_105_055_C.uasset" dialogs="15">
  <Speakers>
    <Speaker id="0" rawBytes="4B 61 7A 75 73 68 69 20 4D 69 79 61 6D 6F 74 6F">Кадзуші Міямото</Speaker>
  </Speakers>
  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 4 101 -1 0 0}{f 3 1 1 0 0 1 0 0}В-воу! {f 4 1}![n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 101 -1 0 0}{f 3 1 1 0 0 2 0 0}{f 4 23 0 105 0 25 25}Друже... Весь час натикаюсь на тебе в найнесподіваніші моменти.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="SEL_001_0_0" type="Selection">
    <Option><![CDATA[{f 0 5 254}{f 2 1}Вже з лікарні?]]></Option>
    <Option><![CDATA[{f 0 5 254}{f 2 1}Злиняв?]]></Option>
  </Dialog>
  <Dialog id="2" name="MSG_002_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 101 -1 0 0}{f 3 1 1 0 0 3 0 0}{f 5 13 8 5 105}Ти ще й згадав, про що ми минулого разу говорили? Від тебе нічого не сховаєш, еге ж?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_003_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 3 101 -1 0 0}{f 3 1 1 0 0 4 0 0}Та ти що, я б ніколи так не вчинив.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_004_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 101 -1 0 0}{f 3 1 1 0 0 5 0 0}Коротше… Я щойно повернувся з лікарні.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 101 -1 0 0}{f 3 1 1 0 0 6 0 0}Прийшли результати мого обстеження.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 3 101 -1 0 0}{f 3 1 1 0 0 7 0 0}{f 4 23 0 105 3 25 25}І... {f 4 1}, Я...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="MSG_005_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 2 101 -1 0 0}{f 3 1 1 0 0 8 0 0}Агх![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MSG_006_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 2 101 -1 0 0}{f 3 1 1 0 0 9 0 0}Бляха... Чому я... не можу стояти!?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="SEL_007_0_0" type="Selection">
    <Option><![CDATA[{f 0 5 254}{f 2 1}Спирайся на мене!]]></Option>
    <Option><![CDATA[{f 0 5 254}{f 2 1}Я тебе піднесу!]]></Option>
    <Option><![CDATA[{f 0 5 254}{f 2 1}Я покличу когось!]]></Option>
  </Dialog>
  <Dialog id="8" name="MSG_008_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 101 -1 0 0}{f 3 1 1 0 0 10 0 0}{f 5 13 8 15 105}Ух...[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 1 101 -1 0 0}{f 3 1 1 0 0 11 0 0}{f 4 23 0 105 1 25 25}Дякую.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="9" name="MSG_009_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 4 101 -1 0 0}{f 3 1 1 0 0 12 0 0}{f 5 13 8 5 105}Якого біса? Я ж не дитина![n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 101 -1 0 0}{f 3 1 1 0 0 13 0 0}{f 4 23 0 105 0 25 25}Але все одно дякую за пропозицію. Можна я просто обіпрусь на тебе?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="10" name="MSG_010_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 2 101 -1 0 0}{f 3 1 1 0 0 14 0 0}П-почекай! Не хочу привертати увагу![n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 3 101 -1 0 0}{f 3 1 1 0 0 15 0 0}{f 4 23 0 105 3 25 25}Усе норм. Просто підстав плече.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="11" name="MSG_011_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 101 -1 0 0}{f 3 1 1 0 0 16 0 0}Смішно, га? Просто присів зашнурувати взуття та отаке...[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 3 101 -1 0 0}{f 3 1 1 0 0 17 0 0}{f 4 23 0 105 3 25 25}Добре, що саме ти поруч був. Якби хтось інший — вся команда вже б знала.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 1 101 -1 0 0}{f 3 1 1 0 0 18 0 0}{f 4 23 0 105 1 25 25}Дякую тобі. Радий, що ти мій друг.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="12" name="MND_012_0_0" type="Message">
    <Page spk="FFFF"><![CDATA[{f 0 5 254}{f 2 1}Здається, Міямото справді цінує мене.[n]{f 1 1}]]></Page>
    <Page spk="FFFF"><![CDATA[{f 0 5 254}{f 2 1}Я відчуваю, що наші стосунки зміцнились...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="13" name="MSG_013_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 1 101 -1 0 0}{f 3 1 1 0 0 19 0 0}Ну що, піду сам трохи потренуюсь.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 101 -1 0 0}{f 3 1 1 0 0 20 0 0}{f 4 23 0 105 0 25 25}Навіть якщо тренування вже закінчилось, я не можу забити. До змагань лишилось не так багато.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 1 101 -1 0 0}{f 3 1 1 0 0 21 0 0}{f 4 23 0 105 1 25 25}Ти ж додому, так? Тоді наступного разу потренуємось разом. Бережи себе![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="14" name="MND_014_0_0" type="Message">
    <Page spk="FFFF"><![CDATA[{f 0 5 254}{f 2 1}Я розійшовся з Міямото[n]й повернувся до гуртожитку.[n]{f 1 1}]]></Page>
  </Dialog>
</BMD>
