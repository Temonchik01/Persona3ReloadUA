  <Dialog id="2" name="MSG_002_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 3 4 -1 -1 0 0}{f 3 1 1 0 0 3 0 0}О-о, це ще гірше, ніж я думав.[n]{f 1 1}]]></Page>
