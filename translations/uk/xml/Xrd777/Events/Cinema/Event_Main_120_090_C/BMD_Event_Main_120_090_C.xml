  </Dialog>
  <Dialog id="41" name="MSG_034_0_0" type="Message">
    <Page spk="000C"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 10 0 -1 -1 0 0}{f 3 1 1 0 0 48 0 0}Йдіть додому. Вам тут не місце.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="42" name="MSG_035_0_0" type="Message">
