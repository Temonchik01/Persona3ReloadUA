  <Dialog id="5" name="MSG_004_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 112 0 -1 -1 0 0}{f 3 1 1 0 0 6 0 0}{f 5 13 15 5 112}Я дуже радий, що ти запитав, {f 4 2}.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 112 0 -1 -1 0 0}{f 3 1 1 0 0 7 0 0}Джіцу ва-взагалі-то, я вигадав план![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MND_005_0_0" type="Message">
    <Page spk="FFFF"><![CDATA[{f 0 5 254}{f 2 1}Здається, Бебе дуже захоплений ідеєю.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MSG_006_0_0" type="Message">
