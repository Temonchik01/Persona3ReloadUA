  <Dialog id="1" name="MSG_001_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 2 0 0}{f 5 21 0 1002}Ага, вже не тягне свого звичного темпу.[n]{f 1 1}]]></Page>
