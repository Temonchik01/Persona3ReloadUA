  <Dialog id="5" name="MSG_005_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 5 0 0}За тиждень місяць знову буде повним.[n]{f 1 1}]]></Page>
