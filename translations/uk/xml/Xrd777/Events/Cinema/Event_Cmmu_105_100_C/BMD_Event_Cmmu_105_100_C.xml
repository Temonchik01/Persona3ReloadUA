  <Speakers>
    <Speaker id="0" rawBytes="59 75 6B 6F 20 4E 69 73 68 69 77 61 6B 69">Юко Нішівакі</Speaker>
    <Speaker id="1" rawBytes="4B 61 7A 75 73 68 69 20 4D 69 79 61 6D 6F 74 6F">Кадзуші Міямото</Speaker>
    <Speaker id="2" rawBytes="53 65 63 6F 6E 64 2D 59 65 61 72 20 43 6C 75 62 20 4D 65 6D 62 65 72">Член гуртка з другого курсу</Speaker>
  </Speakers>
  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 106 0 101 -1 0 0}{f 3 1 1 0 0 1 0 0}Як ти тримаєшся, Кадз?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_001_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 5 151 -1 0 0}{f 3 1 1 0 0 2 0 0}Коліно не дуже... Я не можу сильно на нього спиратись.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="MSG_002_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 106 0 101 -1 0 0}{f 3 1 1 0 0 3 0 0}Гаразд, тоді зробімо перерву раніше.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 106 0 101 -1 0 0}{f 3 1 1 0 0 4 0 0}Не міг би швиденько розім’яти Кадзові ногу?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_003_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 5 0 0}Без проблем. Дай свою ногу.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_004_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 3 151 -1 0 0}{f 3 1 1 0 0 6 0 0}Пробач. Через мене ти пропускаєш тренування.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="MSG_005_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 7 0 0}Не переймайся! Ти ж це заради племінника робиш.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MSG_006_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 3 151 -1 0 0}{f 3 1 1 0 0 8 0 0}Та все одно, мені справді шкода.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MND_007_0_0" type="Message">
    <Page spk="FFFF"><![CDATA[{f 0 5 254}{f 2 1}Після тренування я рушив[n] назад до гуртожитку.[n]{f 1 1}]]></Page>
  </Dialog>
</BMD>
