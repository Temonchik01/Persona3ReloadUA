  <Dialog id="7" name="MSG_006_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 0 -1 -1 0 0}{f 3 1 1 0 0 12 0 0}{f 5 13 13 15 110}Ага, твоя правда. Сподіваюсь...[n]{f 1 1}]]></Page>
  </Dialog>
