    <Speaker id="1" rawBytes="47 6F 73 73 69 70 2D 4C 6F 76 65 72">Любителька пліток</Speaker>
    <Speaker id="2" rawBytes="46 75 75 6B 61 20 59 61 6D 61 67 69 73 68 69">Fuuka Yamagishi</Speaker>
    <Speaker id="3" rawBytes="4E 61 74 73 75 6B 69 20 4D 6F 72 69 79 61 6D 61">Natsuki Moriyama</Speaker>
  </Speakers>
  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 1 0 0}{f 5 21 0 1}Гей, ти чула?[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 2 0 0}{f 5 21 0 1}Схоже, пан Екода влип у халепу![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_001_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 3 0 0}{f 5 21 0 2}Справді? Що він зробив?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="MSG_002_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 4 0 0}{f 5 21 0 1}Не знаю, але, здається, це щось серйозне. Можливо, сексуальне домагання?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_003_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 5 0 0}{f 5 21 0 2}Ха-ха-ха, я це цілком уявляю![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_004_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 6 3 1 -1 0 0}{f 3 1 1 0 0 6 0 0}Е-е-е... Доброго ранку...[n]{f 1 1}]]></Page>
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 6 3 1 -1 0 0}{f 3 1 0 0 0 7 0 0}......[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="MSG_005_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 8 0 0}{f 5 21 0 1}Гей, дивіться. Це дівчина-привид.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MSG_006_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 9 0 0}{f 5 21 0 2}Тихо, вона може вас почути.![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MSG_007_0_0" type="Message">
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 223 0 1 -1 0 0}{f 3 1 1 0 0 10 0 0}О, Фуука, ти тут.![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="8" name="MSG_008_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 6 4 1 -1 0 0}{f 3 1 1 0 0 11 0 0}Моріяма?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="9" name="MSG_009_0_0" type="Message">
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 223 0 1 -1 0 0}{f 3 1 1 0 0 12 0 0}Я чула, ти почала жити в гуртожитку.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="10" name="MSG_010_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 6 0 1 -1 0 0}{f 3 1 1 0 0 13 0 0}Т-Так...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="11" name="MSG_011_0_0" type="Message">
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 223 0 1 -1 0 0}{f 3 1 1 0 0 14 0 0}Ти сьогодні, як завжди, виглядаєш похмурою.[n]{f 1 1}]]></Page>
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 223 0 1 -1 0 0}{f 3 1 1 0 0 15 0 0}Ну, якщо тебе щось турбує, ти завжди можеш поговорити зі мною.[n]{f 1 1}]]></Page>
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 223 0 1 -1 0 0}{f 3 1 1 0 0 16 0 0}Тобі, мабуть, потрібен друг, так?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="12" name="MSG_012_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 6 0 1 -1 0 0}{f 3 1 1 0 0 17 0 0}Моріяма...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="13" name="MSG_013_0_0" type="Message">
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 223 0 1 -1 0 0}{f 3 1 1 0 0 18 0 0}Давай, не будь такою скутою.[n]{f 1 1}]]></Page>
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 223 0 1 -1 0 0}{f 3 1 1 0 0 19 0 0}Просто називай мене Нацукі.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="14" name="MSG_014_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 6 0 1 -1 0 0}{f 3 1 0 0 0 20 0 0}......[n]{f 1 1}]]></Page>
  </Dialog>
