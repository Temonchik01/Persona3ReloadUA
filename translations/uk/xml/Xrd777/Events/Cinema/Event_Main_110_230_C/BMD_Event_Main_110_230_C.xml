    <Speaker id="1" rawBytes="4A 75 6E 70 65 69 20 49 6F 72 69">Джюнпей Іорі</Speaker>
    <Speaker id="2" rawBytes="4D 69 74 73 75 72 75 20 4B 69 72 69 6A 6F">Міцуру Кіріджьо</Speaker>
  </Speakers>
  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 2 3 -1 -1 0 0}{f 3 1 1 0 0 1 0 0}Де вона?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_001_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 3 0 -1 -1 0 0}{f 3 1 1 0 0 2 0 0}Скоро буде.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="MSG_002_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 2 3 -1 -1 0 0}{f 3 1 1 0 0 3 0 0}Зараз повний місяць...[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 2 3 -1 -1 0 0}{f 3 1 1 0 0 4 0 0}У Темну годину він має ще моторошніший вигляд.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_003_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 3 4 -1 -1 0 0}{f 3 1 1 0 0 5 0 0}...Га? Що за...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_004_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 5 0 -1 -1 0 0}{f 3 1 1 0 0 6 0 0}Вибачте за очікування.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="MSG_006_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 5 0 -1 -1 0 0}{f 3 1 1 0 0 7 0 0}Слухайте уважно.[n]{f 1 1}]]></Page>
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 5 0 -1 -1 0 0}{f 3 1 1 0 0 8 0 0}Сьогодні я буду надавати вам підтримку звідси. Усе інше як завжди.[n]{f 1 1}]]></Page>
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 5 0 -1 -1 0 0}{f 3 1 1 0 0 9 0 0}Тінь зараз знаходиться на монорейці, недалеко від станції.[n]{f 1 1}]]></Page>
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 5 0 -1 -1 0 0}{f 3 1 1 0 0 10 0 0}Щоб туди дістатись, вам треба буде пройти по рейках.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MSG_007_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 3 4 -1 -1 0 0}{f 3 1 1 0 0 11 0 0}Е-е, ти серйозно? А це безпечно?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MSG_008_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 5 1 -1 -1 0 0}{f 3 1 1 0 0 12 0 0}Не хвилюйтесь. Під час Темної години електронне обладнання виходить з ладу — у тому числі поїзди.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="8" name="MSG_009_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 3 4 -1 -1 0 0}{f 3 1 1 0 0 13 0 0}Але твій байк?..[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="9" name="MSG_010_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 5 0 -1 -1 0 0}{f 3 1 1 0 0 14 0 0}Він був спеціально створений для такого.[n]{f 1 1}]]></Page>
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 5 0 -1 -1 0 0}{f 3 1 1 0 0 15 0 0}Якщо обставини зміняться, я негайно повідомлю вас.[n]{f 1 1}]]></Page>
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 5 0 -1 -1 0 0}{f 3 1 1 0 0 16 0 0}Гаразд, почнімо![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="10" name="MSG_011_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 2 2 -1 -1 0 0}{f 3 1 1 0 0 17 0 0}Добре.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="11" name="MSG_012_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 3 2 -1 -1 0 0}{f 3 1 1 0 0 18 0 0}Так! Зробімо це![n]{f 1 1}]]></Page>
  </Dialog>
</BMD>
