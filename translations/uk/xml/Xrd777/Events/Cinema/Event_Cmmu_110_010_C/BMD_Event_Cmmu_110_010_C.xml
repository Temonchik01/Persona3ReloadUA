<BMD source="BMD_Event_Cmmu_110_010_C.uasset" sourcePath="D:\Modding\Reloaded 2\Mods\p3r.asset.ukrainian\tools\dds_l10n\source\Xrd777\Events\Cinema\Event_Cmmu_110_010_C\BMD_Event_Cmmu_110_010_C.uasset" dialogs="15">
  <Speakers>
    <Speaker id="0" rawBytes="4D 61 69 6B 6F">Маїко</Speaker>
  </Speakers>
  <Dialog id="0" name="MND_000_0_0" type="Message">
    <Page spk="FFFF"><![CDATA[{f 0 5 254}{f 2 1}Я провів час, граючи з Маіко.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_001_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 1 -1 -1 0 0}{f 3 1 1 0 0 1 0 0}Гей, гей! Що хочеш робити далі?[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 1 -1 -1 0 0}{f 3 1 1 0 0 2 0 0}Твоя черга, гаразд? Обирай![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="SEL_002_0_0" type="Selection">
    <Option><![CDATA[{f 0 5 254}{f 2 1}Гойдалка.]]></Option>
    <Option><![CDATA[{f 0 5 254}{f 2 1}Лазанка.]]></Option>
    <Option><![CDATA[{f 0 5 254}{f 2 1}Рукохід.]]></Option>
    <Option><![CDATA[{f 0 5 254}{f 2 1}Я хочу додому.]]></Option>
  </Dialog>
  <Dialog id="3" name="MSG_003_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 1 0 0 3 0 0}Оой, я ненавиджу гойдалку! Мені сидіти боляче...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_004_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 1 -1 -1 0 0}{f 3 1 1 0 0 4 0 0}О, ура! Я обожнюю лазити на всяких штуках![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="MSG_005_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 1 0 0 5 0 0}Ми вже там грались! Я хочу чогось іншого![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MSG_006_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 1 0 0 6 0 0}Еех, ти вже йдеш?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MND_006_5_0" type="Message">
    <Page spk="FFFF"><![CDATA[{f 0 5 254}{f 2 1}Здається, скоро стемніє...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="8" name="MSG_007_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 1 0 0 7 0 0}Я не хочу додому...[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 1 0 0 8 0 0}Мені там не подобається.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="9" name="MSG_008_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 0 -1 -1 0 0}{f 3 1 1 0 0 9 0 0}Можемо залишитися тут ще трохи?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="10" name="MND_009_0_0" type="Message">
    <Page spk="FFFF"><![CDATA[{f 0 5 254}{f 2 1}Після гри, схоже,[n]я починаю їй подобатись...[n]{f 1 1}]]></Page>
    <Page spk="FFFF"><![CDATA[{f 0 5 254}{f 2 1}Я познайомився з[n]Маіко, першокласницею.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="11" name="MSG_010_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 1 0 0 10 0 0}Знаєш, моя мама з татом...[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 1 0 0 11 0 0}Вони весь час сваряться... І якось...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="12" name="MSG_010_3_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 1 0 0 12 0 0}Вони сказали, що розлучаються.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 1 0 0 13 0 0}Я попросила їх не робити цього, але вони не слухають.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 1 0 0 14 0 0}Я думаю, що я їм не потрібна.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 2 -1 -1 0 0}{f 3 1 0 0 0 15 0 0}......[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="13" name="MSG_010_5_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 0 -1 -1 0 0}{f 3 1 1 0 0 16 0 0}Ей... Пограєш зі мною ще якось? Ми ж друзі тепер![n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 110 0 -1 -1 0 0}{f 3 1 1 0 0 17 0 0}Я буваю тут {f 0 1 2}щопонеділка, щосереди й щосуботи{f 0 1 27}... Прийдеш до мене, добре?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="14" name="MND_011_0_0" type="Message">
    <Page spk="FFFF"><![CDATA[{f 0 5 254}{f 2 1}Я розпрощався з Маіко,[n]а потім повернувся до гуртожитку.[n]{f 1 1}]]></Page>
  </Dialog>
</BMD>
