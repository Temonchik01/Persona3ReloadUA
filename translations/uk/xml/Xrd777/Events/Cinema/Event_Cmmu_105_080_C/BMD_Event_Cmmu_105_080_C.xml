  <Dialog id="3" name="MSG_003_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 3 151 -1 0 0}{f 3 1 1 0 0 4 0 0}Я ж просто... тренувався?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_004_0_0" type="Message">
