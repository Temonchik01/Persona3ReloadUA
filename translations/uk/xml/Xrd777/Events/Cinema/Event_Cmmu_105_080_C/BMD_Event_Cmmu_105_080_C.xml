  <Dialog id="1" name="MSG_001_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 105 0 151 -1 0 0}{f 3 1 1 0 0 2 0 0}Щ-що таке? І чого такий сердитий вигляд?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="MSG_002_0_0" type="Message">
