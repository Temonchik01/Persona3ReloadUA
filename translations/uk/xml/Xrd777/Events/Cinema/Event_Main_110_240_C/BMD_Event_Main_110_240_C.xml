  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 2 3 51 -1 0 0}{f 3 1 1 0 0 1 0 0}Це тут... так?[n]{f 1 1}]]></Page>
