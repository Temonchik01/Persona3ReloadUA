  </Dialog>
  <Dialog id="10" name="MND_010_0_0" type="Message">
    <Page spk="0007"><![CDATA[{f 0 5 254}{f 2 1}The final battle is here...[n]{f 1 1}]]></Page>
    <Page spk="0007"><![CDATA[{f 0 5 254}{f 2 1}The last Shadow and Strega await us.[n]{f 1 1}]]></Page>
    <Page spk="0007"><![CDATA[{f 0 5 254}{f 2 1}This is serious. I should choose[n]my team lineup carefully...[n]{f 1 1}]]></Page>
