<BMD source="BMD_Event_Main_130_040_C.uasset" sourcePath="D:\Modding\Reloaded 2\Mods\p3r.asset.ukrainian\tools\dds_l10n\source\Xrd777\Events\Cinema\Event_Main_130_040_C\BMD_Event_Main_130_040_C.uasset" dialogs="13">
  <Speakers>
    <Speaker id="0" rawBytes="4D 79 73 74 65 72 69 6F 75 73 20 42 6F 79">Mysterious Boy</Speaker>
    <Speaker id="1" rawBytes="50 68 61 72 6F 73">Pharos</Speaker>
  </Speakers>
  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 0 1 0 0}Ти знову переміг.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_001_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 2 0 0}Пам'ятаєш, що я казав раніше?[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 3 0 0}Про те, що все колись закінчується?[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 4 0 0}Ну, я згадав ще дещо.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="MSG_001_5_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 5 0 0}Я впевнений, що кінець неминучий.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_002_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 6 0 0}Але це трохи дивно.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 7 0 0}Бо зараз це не здається таким неминучим, з огляду на твій величезний потенціал.[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 8 0 0}До того ж, здається, твоя сила дещо змінилася.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_003_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 1 -1 -1 0 0}{f 3 1 1 0 0 9 0 0}Гей, якщо ти не проти, я можу бути твоїм другом?[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 1 -1 -1 0 0}{f 3 1 1 0 0 10 0 0}Мені дуже цікаво про тебе дізнатися. Що скажеш?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="SEL_004_0_0" type="Selection">
    <Option><![CDATA[{f 0 5 254}{f 2 1}Мені підходить.]]></Option>
    <Option><![CDATA[{f 0 5 254}{f 2 1}Звісно, як тебе звати?]]></Option>
    <Option><![CDATA[{f 0 5 254}{f 2 1}Так, як скажеш.]]></Option>
  </Dialog>
  <Dialog id="6" name="MSG_005_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 11 0 0}Гаразд. Тоді відтепер ми друзі.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MSG_006_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 12 0 0}Ім'я?..[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 13 0 0}А, зрозумів. Мені потрібно ім'я.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="8" name="MSG_007_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 14 0 0}Хе-хе, мабуть, тобі це не дуже важливо. Можливо, мені не варто було про це згадувати, гм?[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 15 0 0}Ми з тобою разом від самого початку.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="9" name="MSG_008_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 16 0 0}Мене звати... Фароз.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="10" name="MSG_009_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 1 -1 -1 0 0}{f 3 1 1 0 0 17 0 0}Я знаю, що ми чудово порозуміємося.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="11" name="MND_010_0_0" type="Message">
    <Page spk="FFFF"><![CDATA[{f 0 5 254}{f 2 1}Я відчуваю початок зв'язку зі[n]загадковим хлопчиком, Фарозом....[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="12" name="MSG_011_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 0 -1 -1 0 0}{f 3 1 1 0 0 18 0 0}Ну, вже пізно, тож я піду.[n]{f 1 1}]]></Page>
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 1 -1 -1 0 0}{f 3 1 1 0 0 19 0 0}Не можу дочекатися нашої наступної зустрічі.[n]{f 1 1}]]></Page>
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 111 1 -1 -1 0 0}{f 3 1 1 0 0 20 0 0}Бувай.[n]{f 1 1}]]></Page>
  </Dialog>
</BMD>
