  </Dialog>
  <Dialog id="2" name="MSG_001_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 4 5 3 0 5 -1 0 0}{f 3 1 1 0 0 3 0 0}Oh, it's her.[n]{f 1 1}]]></Page>
