  <Speakers>
    <Speaker id="0" rawBytes="46 61 6D 69 6C 69 61 72 20 4D 61 6E">Familiar Man</Speaker>
    <Speaker id="1" rawBytes="4D 61 69 6B 6F 27 73 20 44 61 64">Maiko's Dad</Speaker>
  </Speakers>
  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 6 1 12 0}Hm? You're...[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 6 2 12 0}Ah, {f 4 1}-kun, right?[n]{f 1 1}]]></Page>
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 6 3 12 0}I'm... Maiko's father, if you remember.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_001_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 6 4 12 0}Do you have a minute to talk? I've been dwelling a little on what happened...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="SEL_002_0_0" type="Selection">
    <Option><![CDATA[{f 0 5 254}{f 2 1}All right.]]></Option>
    <Option><![CDATA[{f 0 5 254}{f 2 1}I'm a bit busy today...]]></Option>
  </Dialog>
  <Dialog id="3" name="MSG_003_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 6 5 12 0}Perfect. If you don't mind, let's take a walk down to the takoyaki stand. I'll buy you some—my treat.[n]{f 1 1}]]></Page>
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 6 6 12 0}The food there sure is good... But you knew that already, didn't you?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_004_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 6 7 12 0}Oh. That's too bad...[n]{f 1 1}]]></Page>
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 6 8 12 0}I was just thinking of Maiko when you happened to show up.[n]{f 1 1}]]></Page>
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}{f 3 1 1 0 6 9 12 0}Sorry for imposing.[n]{f 1 1}]]></Page>
  </Dialog>
