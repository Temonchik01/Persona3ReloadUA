  <Dialog id="0" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Я згадала...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_000_5_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Саме так. Після смерті мого батька... був час,[n]коли я втратила мотивацію жити своїм життям.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="MSG_001_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}Га? Я... щось забула?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_002_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}Га? Санадо?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_002_5_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}Щ-що ти робиш?![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="MSG_003_0_0" type="Message">
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}...Коромару![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MSG_004_0_0" type="Message">
    <Page spk="0004"><![CDATA[{f 0 5 254}{f 2 1}Арф![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MSG_005_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Але вже ні. Я виконаю волю свого батька.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="8" name="MSG_005_3_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Я не буду тікати від майбутнього... Я зустріну його віч-на-віч.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="9" name="MSG_005_5_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}У мене не залишилося[n]жодного сумніву. І причина...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="10" name="MSG_006_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}Наша обіцянка![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="11" name="MSG_007_0_0" type="Message">
    <Page spk="0005"><![CDATA[{f 0 5 254}{f 2 1}Міцуру![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="12" name="MSG_008_0_0" type="Message">
    <Page spk="0006"><![CDATA[{f 0 5 254}{f 2 1}Точно!..[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="13" name="MSG_009_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Бо я завела таких чудових друзів...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="14" name="MSG_009_5_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}І ми поклялися, що ніколи не втрачатимемо надії,[n]що б не чекало на нас у майбутньому![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="15" name="MSG_010_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}Міцуру! Ми згадали його та Аїґіс![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="16" name="MSG_011_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Так, я теж.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="17" name="MSG_012_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Ходімо... Вони чекають.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="18" name="MSG_013_0_0" type="Message">
    <Page spk="0007"><![CDATA[{f 0 5 254}{f 2 1}Агов? Це церемонія! Ми ще не закінчили![n]{f 1 1}]]></Page>
  </Dialog>
</BMD>
