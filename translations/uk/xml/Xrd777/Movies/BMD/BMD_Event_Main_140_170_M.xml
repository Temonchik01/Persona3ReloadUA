  <Dialog id="0" name="MSG_000_5_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Ох!..[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_000_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}На що ти дивишся?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="MSG_001_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Привітайте учасницю номер один —[n]Юкарі Такеба! Досить сміливий дизайн![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_001_3_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Вона справді хизується! Стрільба з лука[n]творить чудеса із самооцінкою![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_001_5_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}Бле-е![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="MSG_001_7_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Га?..[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MSG_002_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}Якщо на парасольки ніхто не претендує,[n]як гадаєте, ми можемо їх використати?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MSG_003_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}О-о! Наступна учасниця[n]номер два — Фуука Ямаґіші![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="8" name="MSG_003_5_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Ого, Фууко... а ти...[n]часто одягаєш купальники чи?..[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="9" name="MSG_004_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}Е-е?..[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="10" name="MSG_005_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Упс, я щось не те сказав?[n]Не хотів тебе соромити![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="11" name="MSG_005_5_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Хе-хе-хе.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="12" name="MSG_006_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}Припини реготати, виродку.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="13" name="MSG_007_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}І остання учасниця сьогоднішнього дня...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="14" name="MSG_008_0_0" type="Message">
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}Що сталося? Щось не так?[n]{f 1 1}]]></Page>
  </Dialog>
