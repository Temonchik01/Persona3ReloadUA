  <Dialog id="2" name="MSG_002_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Hey, so... If you're gonna[n]live in the dorms next year...[n]{f 1 1}]]></Page>
