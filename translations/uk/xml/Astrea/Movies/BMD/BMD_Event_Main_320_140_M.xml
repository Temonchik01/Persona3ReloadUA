  <Dialog id="0" name="MSG_016_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Wha...!?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="1" name="MSG_017_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}Ah...![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="2" name="MSG_000_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}No![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="3" name="MSG_001_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}This is... not a Shadow...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="4" name="MSG_002_0_0" type="Message">
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}?..![n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="5" name="MSG_003_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}I think it's...[n]It's all of humanity's...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="6" name="MSG_004_0_0" type="Message">
    <Page spk="0004"><![CDATA[{f 0 5 254}{f 2 1}Just as I thought... The purpose of his seal—[cr][n]It's not meant to hold back Nyx.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="7" name="MSG_004_1_0" type="Message">
    <Page spk="0004"><![CDATA[{f 0 5 254}{f 2 1}It's to prevent something from reaching her.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="8" name="MSG_005_0_0" type="Message">
    <Page spk="0005"><![CDATA[{f 0 5 254}{f 2 1}What do you mean?[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="9" name="MSG_006_0_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}That giant monster...[n]It's not a Shadow...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="10" name="MSG_006_1_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}It's... a mass of the worst traits and[n]feelings from every person's heart...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="11" name="MSG_006_2_0" type="Message">
    <Page spk="0002"><![CDATA[{f 0 5 254}{f 2 1}Deep down...[n]Everyone is calling for Nyx...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="12" name="MSG_007_0_0" type="Message">
    <Page spk="0003"><![CDATA[{f 0 5 254}{f 2 1}That can't be...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="13" name="MSG_008_0_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}There was a time...[n]when I also wished for death.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="14" name="MSG_008_1_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}It's probably true that everyone has[n]a part of them secretly yearning for it...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="15" name="MSG_008_2_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}The only thing that separates[n]the living from the nonliving...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="16" name="MSG_008_3_0" type="Message">
    <Page spk="0000"><![CDATA[{f 0 5 254}{f 2 1}Is death... The greatest equalizer.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="17" name="MSG_009_0_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}I think I understand...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="18" name="MSG_009_1_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}When you feel like your life has no meaning,[n]the thought of death can be comforting...[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="19" name="MSG_009_2_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}And that subconscious desire is so strong...[n]it could even create a monster like this.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="20" name="MSG_009_3_0" type="Message">
    <Page spk="0001"><![CDATA[{f 0 5 254}{f 2 1}I guess that's... just how it is these days.[n]{f 1 1}]]></Page>
  </Dialog>
  <Dialog id="21" name="MSG_010_0_0" type="Message">
    <Page spk="0006"><![CDATA[{f 0 5 254}{f 2 1}What the hell...!?[n]{f 1 1}]]></Page>
  </Dialog>
</BMD>
